parse_args() {
    while [[ $# -gt 0 ]]; do
        case $1 in
            --style)
                if [ -z "${2:-}" ]; then
                    print_error "--style requires a value"
                    exit 1
                fi
                STANDUP_STYLE="$2"
                shift 2
                ;;
            --org)
                if [ -z "${2:-}" ]; then
                    print_error "--org requires a value"
                    exit 1
                fi
                STANDUP_ORG="$2"
                # Save as new default
                local _cfg="${HOME}/.config/gh-standup/config"
                mkdir -p "$(dirname "$_cfg")"
                echo "org=$STANDUP_ORG" > "$_cfg"
                shift 2
                ;;
            --summary)
                STANDUP_SUMMARY=1
                shift
                ;;
            --no-summary)
                STANDUP_SUMMARY=0
                shift
                ;;
            --model)
                if [ -z "${2:-}" ]; then
                    print_error "--model requires a value"
                    exit 1
                fi
                STANDUP_SUMMARY_MODEL="$2"
                shift 2
                ;;
            --provider)
                if [ -z "${2:-}" ]; then
                    print_error "--provider requires a value (fireworks or claude)"
                    exit 1
                fi
                STANDUP_SUMMARY_PROVIDER="$2"
                shift 2
                ;;
            -h|--help)
                echo "Usage: standup-report [OPTIONS]"
                echo ""
                echo "Options:"
                echo "  --style STYLE  Rendering style: box, colorful, table, minimal (default: box)"
                echo "  --org ORG      GitHub org to search PRs in (auto-detected if not set)"
                echo "  --summary      Enable AI summary (default)"
                echo "  --no-summary   Disable AI summary"
                echo "  --model MODEL  Fireworks model ID (default: kimi-k2p5-turbo)"
                echo "  --provider P   Summary provider: fireworks or claude (default: fireworks)"
                echo "  -h, --help     Show this help"
                echo ""
                echo "Environment variables:"
                echo "  STANDUP_STYLE          Default style (default: box)"
                echo "  STANDUP_ORG            GitHub org (auto-detected if not set)"
                echo "  STANDUP_SUMMARY        AI summary: 1=on, 0=off (default: 1)"
                echo "  STANDUP_SUMMARY_MODEL  Fireworks model (default: kimi-k2p5-turbo)"
                echo "  STANDUP_SUMMARY_PROVIDER  fireworks or claude (default: fireworks)"
                echo "  LINEAR_RECENCY_DAYS    Days to look back for Linear issues (default: 30)"
                echo "  STANDUP_NO_HYPERLINKS  Set to 1 to disable clickable links"
                exit 0
                ;;
            *)
                print_error "Unknown option: $1"
                echo "Use --help for usage information"
                exit 1
                ;;
        esac
    done
}

# ============================================================
# Main (parallelized data fetching)
# ============================================================

main() {
    parse_args "$@"

    check_dependencies

    # Load saved config
    local config_file="${HOME}/.config/gh-standup/config"
    if [ -z "$STANDUP_ORG" ] && [ -f "$config_file" ]; then
        STANDUP_ORG=$(grep '^org=' "$config_file" 2>/dev/null | cut -d= -f2-)
    fi

    # Require org — prompt user to choose if not set
    if [ -z "$STANDUP_ORG" ]; then
        local orgs
        orgs=$(gh api user/orgs --jq '.[].login' 2>/dev/null)
        local username
        username=$(gh api user --jq '.login' 2>/dev/null)

        if [ -z "$orgs" ] && [ -z "$username" ]; then
            print_error "Could not fetch GitHub orgs. Specify one with --org or STANDUP_ORG env var."
            exit 1
        fi

        echo -e "${BOLD}Select a GitHub org:${NC}"
        echo ""

        local options=()
        [ -n "$username" ] && options+=("$username (personal)")
        while IFS= read -r org; do
            [ -n "$org" ] && options+=("$org")
        done <<< "$orgs"

        local i=1
        for opt in "${options[@]}"; do
            echo -e "  ${BOLD}$i)${NC} $opt"
            i=$((i + 1))
        done
        echo ""
        printf "  Enter number: "
        read -r choice

        if [ -z "$choice" ] || [ "$choice" -lt 1 ] || [ "$choice" -gt ${#options[@]} ] 2>/dev/null; then
            print_error "Invalid choice."
            exit 1
        fi

        local selected="${options[$((choice - 1))]}"
        # Strip " (personal)" suffix if present
        STANDUP_ORG=$(echo "$selected" | sed 's/ (personal)$//')

        # Save selection
        mkdir -p "$(dirname "$config_file")"
        echo "org=$STANDUP_ORG" > "$config_file"

        echo ""
        print_info "Saved to ${DIM}$config_file${NC} (change with ${BOLD}gh standup --org OTHER${NC})"
        echo ""
    fi

    local today=$(get_today_date)
    local yesterday=$(get_yesterday_date)

    # Temp files for parallel output
    local tmp_prs=$(mktemp)
    local tmp_merged=$(mktemp)
    local tmp_review=$(mktemp)
    local tmp_linear=$(mktemp)

    # Launch all 4 fetches in parallel
    printf "${DIM}Fetching data from GitHub + Linear...${NC}"
    (get_authored_prs "$yesterday" "$STANDUP_ORG" > "$tmp_prs" 2>/dev/null) &
    local pid_prs=$!
    (get_merged_prs "$yesterday" "$STANDUP_ORG" > "$tmp_merged" 2>/dev/null) &
    local pid_merged=$!
    (get_review_requested_prs "$STANDUP_ORG" > "$tmp_review" 2>/dev/null) &
    local pid_review=$!
    (get_linear_issues > "$tmp_linear" 2>/dev/null) &
    local pid_linear=$!

    # Wait for all
    wait $pid_prs $pid_merged $pid_review $pid_linear 2>/dev/null || true

    local prs_json=$(cat "$tmp_prs" 2>/dev/null || echo "[]")
    local merged_json=$(cat "$tmp_merged" 2>/dev/null || echo "[]")
    local prs_needing_review_json=$(cat "$tmp_review" 2>/dev/null || echo "[]")
    local linear_issues_json=$(cat "$tmp_linear" 2>/dev/null || echo "[]")

    rm -f "$tmp_prs" "$tmp_merged" "$tmp_review" "$tmp_linear"

    # Validate JSON
    echo "$prs_json" | jq empty 2>/dev/null || prs_json="[]"
    echo "$merged_json" | jq empty 2>/dev/null || merged_json="[]"
    echo "$prs_needing_review_json" | jq empty 2>/dev/null || prs_needing_review_json="[]"
    echo "$linear_issues_json" | jq empty 2>/dev/null || linear_issues_json="[]"

    # Clear the loading message
    printf "\r\033[K"

    generate_standup_report "$prs_json" "$prs_needing_review_json" "$linear_issues_json" "$today" "$merged_json"
}

main "$@"
