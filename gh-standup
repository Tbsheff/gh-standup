generate_summary() {
    local prs_json="$1"
    local prs_needing_review_json="$2"
    local linear_issues_json="$3"
    local merged_json="${4:-[]}"

    # Build rich context for the summary — PR descriptions tell the real story
    local data_file=$(mktemp)

    # Merged PRs: include description + scale for real context
    echo "=== MERGED PRs (what shipped) ===" >> "$data_file"
    local merged_count=$(echo "$merged_json" | jq -r 'length' 2>/dev/null || echo "0")
    if [ "${merged_count:-0}" -gt 0 ]; then
        echo "$merged_json" | jq -r '.[] | "PR: \(.title)\nDescription: \(.body // "no description")\nScale: +\(.additions // 0)/-\(.deletions // 0) across \(.changedFiles // 0) files\n"' 2>/dev/null >> "$data_file"
    else
        echo "(nothing merged)" >> "$data_file"
    fi

    # Open PRs: just titles (enough for today's plan)
    echo "=== OPEN PRs (in progress) ===" >> "$data_file"
    local open_count=$(echo "$prs_json" | jq -r '[.[] | select(.isDraft == false)] | length' 2>/dev/null || echo "0")
    if [ "${open_count:-0}" -gt 0 ]; then
        echo "$prs_json" | jq -r '[.[] | select(.isDraft == false)] | .[] | "- \(.title)"' 2>/dev/null >> "$data_file"
    else
        echo "(nothing in progress)" >> "$data_file"
    fi

    # Blockers
    echo "" >> "$data_file"
    echo "=== BLOCKERS ===" >> "$data_file"
    local review_count=$(echo "$prs_needing_review_json" | jq -r 'length' 2>/dev/null || echo "0")
    local changes_count=$(echo "$prs_json" | jq '[.[] | select(.reviewDecision == "CHANGES_REQUESTED")] | length' 2>/dev/null || echo "0")
    if [ "${review_count:-0}" -gt 0 ] || [ "${changes_count:-0}" -gt 0 ]; then
        [ "${changes_count:-0}" -gt 0 ] && echo "$prs_json" | jq -r '[.[] | select(.reviewDecision == "CHANGES_REQUESTED")] | .[] | "- Changes requested on: \(.title)"' 2>/dev/null >> "$data_file"
        [ "${review_count:-0}" -gt 0 ] && echo "$prs_needing_review_json" | jq -r '.[] | "- Needs review: \(.title) by @\(.author.login)"' 2>/dev/null >> "$data_file"
    else
        echo "- None" >> "$data_file"
    fi

    local system_prompt="You write standup updates from PR data. Output ONLY valid JSON. No markdown. No explanation."
    local user_prompt="Read these PRs and write a standup that explains what was actually accomplished, not just PR titles.

Bad example (just rephrases titles):
{\"yesterday\":[\"add DI pattern for libcore database access\",\"enforce ctx.db in tRPC routers\"]}

Good example (explains what was done and why):
{\"yesterday\":[\"Laid foundation for database dependency injection — new libcore access pattern replaces direct prisma imports, with lint rule to enforce usage in routers\",\"Fixed delivery loop state sync bug where review head SHA diverged from QA checks\"]}

Rules:
- yesterday: what shipped. Use the PR description to understand what was actually done. Explain the WHY and IMPACT, not just the what.
- today: what's planned. Infer the goal from open PR titles.
- blockers: changes requested or reviews needed. Say None if clear.
- 2-4 bullets per section. Group related PRs into one bullet.
- Do NOT just rephrase PR titles. Summarize the actual work.

Output as JSON: {\"yesterday\":[...],\"today\":[...],\"blockers\":[...]}

$(cat "$data_file")"

    local output=""

    if [ "$STANDUP_SUMMARY_PROVIDER" = "fireworks" ]; then
        # Fireworks Anthropic-compatible API (separates thinking from content)
        if [ -z "${FIREWORKS_API_KEY:-}" ]; then
            rm -f "$data_file"
            return 1
        fi

        # Write prompt to file so jq can read it with proper escaping
        # (--arg doesn't handle embedded newlines in shell variables)
        local prompt_file=$(mktemp)
        echo "$user_prompt" > "$prompt_file"

        local payload
        payload=$(jq -n \
            --arg model "$STANDUP_SUMMARY_MODEL" \
            --arg system "$system_prompt" \
            --rawfile user "$prompt_file" \
            '{
                model: $model,
                max_tokens: 4096,
                thinking: {type: "enabled", budget_tokens: 2000},
                system: $system,
                messages: [
                    {role: "user", content: $user}
                ]
            }')
        rm -f "$prompt_file"

        output=$(curl -s --max-time 45 \
            https://api.fireworks.ai/inference/v1/messages \
            -H "x-api-key: $FIREWORKS_API_KEY" \
            -H "Content-Type: application/json" \
            -H "anthropic-version: 2023-06-01" \
            -d "$payload" 2>/dev/null | jq -r '.content[] | select(.type == "text") | .text' 2>/dev/null || echo "")
    else
        # Claude CLI fallback
        if ! command -v claude &> /dev/null; then
            rm -f "$data_file"
            return 1
        fi
        output=$(timeout 45 claude --model haiku -p "$user_prompt" < /dev/null 2>/dev/null || echo "")
    fi

    rm -f "$data_file"

    if [ -z "$output" ]; then
        return 1
    fi

    # Extract JSON from the output (handles reasoning models that prefix with thinking)
    local json
    json=$(echo "$output" | grep -o '{.*}' | tail -1)

    if [ -n "$json" ] && echo "$json" | jq empty 2>/dev/null; then
        echo "$json"
    else
        return 1
    fi
}

