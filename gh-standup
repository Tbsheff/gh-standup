#!/bin/bash

# Standup Report Script
# =====================
# Generates a standup report: PRs opened (today + yesterday), PRs needing review,
# and open Linear issues. Uses GitHub GraphQL for cross-repo PR search.
#
# Usage: standup-report --org YOUR_ORG [--style STYLE] [--no-summary] [--help]

set -euo pipefail

# Configuration (override via env vars or CLI flags)
STANDUP_ORG=${STANDUP_ORG:-}
LINEAR_RECENCY_DAYS=${LINEAR_RECENCY_DAYS:-30}
STANDUP_STYLE=${STANDUP_STYLE:-box}
STANDUP_SUMMARY=${STANDUP_SUMMARY:-1}  # AI summary: 1=on, 0=off
STANDUP_SUMMARY_MODEL=${STANDUP_SUMMARY_MODEL:-accounts/fireworks/routers/kimi-k2p5-turbo}
STANDUP_SUMMARY_PROVIDER=${STANDUP_SUMMARY_PROVIDER:-fireworks}  # fireworks or claude

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
WHITE='\033[1;37m'
BOLD='\033[1m'
DIM='\033[2m'
UNDERLINE='\033[4m'
NC='\033[0m'

# Background colors
BG_BLUE='\033[44m'
BG_GREEN='\033[42m'
BG_YELLOW='\033[43m'
BG_RED='\033[41m'
BG_CYAN='\033[46m'
BG_MAGENTA='\033[45m'

# Box-drawing characters
BOX_H='─'
BOX_V='│'
BOX_TL='┌'
BOX_TR='┐'
BOX_BL='└'
BOX_BR='┘'
BOX_T='┬'
BOX_B='┴'
BOX_L='├'
BOX_R='┤'
BOX_C='┼'

# Function to print colored output
print_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

print_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

print_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# Design helper functions
draw_box() {
    local width="${1:-80}"
    local title="$2"
    local style="${3:-single}"

    if [ "$style" = "double" ]; then
        local h='═'
        local v='║'
        local tl='╔'
        local tr='╗'
        local bl='╚'
        local br='╝'
    else
        local h="$BOX_H"
        local v="$BOX_V"
        local tl="$BOX_TL"
        local tr="$BOX_TR"
        local bl="$BOX_BL"
        local br="$BOX_BR"
    fi

    if [ -n "$title" ]; then
        local title_len=${#title}
        local padding=$((width - title_len - 2))
        local left_pad=$((padding / 2))
        local right_pad=$((padding - left_pad))
        echo -e "${tl}$(printf "%*s" $((width - 2)) | tr ' ' "$h")${tr}"
        echo -e "${v}$(printf "%*s" $left_pad | tr ' ' ' ')${title}$(printf "%*s" $right_pad | tr ' ' ' ')${v}"
        echo -e "${bl}$(printf "%*s" $((width - 2)) | tr ' ' "$h")${br}"
    else
        echo -e "${tl}$(printf "%*s" $((width - 2)) | tr ' ' "$h")${tr}"
    fi
}

draw_box_bottom() {
    local width="${1:-80}"
    local style="${2:-single}"

    if [ "$style" = "double" ]; then
        local bl='╚'
        local br='╝'
        local h='═'
    else
        local bl="$BOX_BL"
        local br="$BOX_BR"
        local h="$BOX_H"
    fi

    echo -e "${bl}$(printf "%*s" $((width - 2)) | tr ' ' "$h")${br}"
}

print_header() {
    local text="$1"
    local color="${2:-$BLUE}"
    local bg_color="${3:-}"
    local width="${4:-80}"

    if [ -n "$bg_color" ]; then
        echo -e "${bg_color}${WHITE}${BOLD}$(printf "%-${width}s" "$text")${NC}"
    else
        local padding=$((width - ${#text} - 4))
        echo -e "${color}${BOLD}╔$(printf "%*s" $((width - 2)) | tr ' ' '═')╗${NC}"
        echo -e "${color}${BOLD}║${NC}  ${BOLD}${text}${NC}$(printf "%*s" $padding | tr ' ' ' ')${color}${BOLD}║${NC}"
        echo -e "${color}${BOLD}╚$(printf "%*s" $((width - 2)) | tr ' ' '═')╝${NC}"
    fi
}

print_section_header() {
    local text="$1"
    local icon="$2"
    local color="${3:-$CYAN}"

    echo ""
    echo -e "${color}${BOLD}${BOX_L}─ ${icon} ${text}${NC}"
    echo -e "${color}${BOX_V}${NC}"
}

print_badge() {
    local text="$1"
    local color="${2:-$GREEN}"
    local bg="${3:-}"

    if [ -n "$bg" ]; then
        echo -e "${bg}${WHITE}${BOLD} ${text} ${NC}"
    else
        echo -e "${color}${BOLD}[${text}]${NC}"
    fi
}

truncate_text() {
    local text="$1"
    local max_len="${2:-60}"

    if [ ${#text} -le "$max_len" ]; then
        echo "$text"
    else
        echo "${text:0:$((max_len - 3))}..."
    fi
}

get_terminal_width() {
    local width
    width=$(tput cols 2>/dev/null || echo "80")
    if [ -z "$width" ] || [ "$width" -lt 40 ]; then
        width=80
    fi
    echo "$width"
}

# Create clickable hyperlink (OSC 8 protocol)
make_link() {
    local url="$1"
    local text="${2:-$url}"

    if [ "${STANDUP_NO_HYPERLINKS:-}" = "1" ]; then
        echo "$text"
        return
    fi

    printf '\033]8;;%s\033\\%s\033]8;;\033\\' "$url" "$text"
}

make_button_link() {
    local url="$1"
    local text="${2:-Open}"
    local color="${3:-$CYAN}"
    local link_text=$(make_link "$url" "$text")
    echo -e "${color}${BOLD}[${link_text}]${NC}"
}

# Check if required tools are installed
check_dependencies() {
    local missing_deps=()

    if ! command -v gh &> /dev/null; then
        missing_deps+=("gh (GitHub CLI)")
    fi

    if ! command -v jq &> /dev/null; then
        missing_deps+=("jq")
    fi

    if [ ${#missing_deps[@]} -gt 0 ]; then
        print_error "Missing required dependencies:"
        for dep in "${missing_deps[@]}"; do
            echo "  - $dep"
        done
        echo ""
        print_info "Install missing dependencies:"
        echo "  brew install gh jq"
        exit 1
    fi

    if ! command -v linear &> /dev/null; then
        print_info "Note: Linear CLI not found. Linear issues will be skipped."
        print_info "Install with: brew install linear"
    fi
}

# Get today's date in YYYY-MM-DD format
get_today_date() {
    date +%Y-%m-%d
}

# Get yesterday's date in YYYY-MM-DD format
get_yesterday_date() {
    if [[ "$OSTYPE" == "darwin"* ]]; then
        date -v-1d +%Y-%m-%d
    else
        date -d "yesterday" +%Y-%m-%d
    fi
}

# Get current GitHub username
get_current_user() {
    gh api user --jq '.login'
}

# Format PR status with enhanced badges
format_pr_status() {
    local pr_json="$1"
    local style="${2:-default}"
    local status_parts=()

    local is_draft=$(echo "$pr_json" | jq -r '.isDraft')
    local review_decision=$(echo "$pr_json" | jq -r '.reviewDecision // "null"')

    if [ "$style" = "badge" ]; then
        if [ "$is_draft" = "true" ]; then
            status_parts+=("${YELLOW}${BG_YELLOW}${WHITE} DRAFT ${NC}")
        else
            status_parts+=("${GREEN}${BG_GREEN}${WHITE} READY ${NC}")
        fi

        if [ "$review_decision" = "APPROVED" ]; then
            status_parts+=("${CYAN}${BG_CYAN}${WHITE} APPROVED ${NC}")
        elif [ "$review_decision" = "CHANGES_REQUESTED" ]; then
            status_parts+=("${RED}${BG_RED}${WHITE} CHANGES ${NC}")
        elif [ "$review_decision" = "REVIEW_REQUIRED" ] || [ "$review_decision" = "null" ]; then
            status_parts+=("${YELLOW}${BG_YELLOW}${WHITE} REVIEW ${NC}")
        fi
    else
        if [ "$is_draft" = "true" ]; then
            status_parts+=("📝 Draft")
        else
            status_parts+=("✅ Ready")
        fi

        if [ "$review_decision" = "APPROVED" ]; then
            status_parts+=("✅ Approved")
        elif [ "$review_decision" = "CHANGES_REQUESTED" ]; then
            status_parts+=("⚠️ Changes Requested")
        elif [ "$review_decision" = "REVIEW_REQUIRED" ] || [ "$review_decision" = "null" ]; then
            status_parts+=("⏳ Review Required")
        fi
    fi

    local labels=$(echo "$pr_json" | jq -r '.labels[].name' 2>/dev/null | tr '\n' ',' | sed 's/,$//')
    if [ -n "$labels" ]; then
        status_parts+=("🏷️ $labels")
    fi

    local result=""
    for i in "${!status_parts[@]}"; do
        if [ $i -gt 0 ]; then
            result+=" "
        fi
        result+="${status_parts[$i]}"
    done
    echo "$result"
}

# Extract short repo name from "org/repo" format
repo_short() {
    echo "$1" | sed 's|.*/||'
}

# Word-wrap a bullet point with box-drawing prefix
# First line gets "- ", continuation lines align after it
wrap_bullet() {
    local text="$1"
    local color="${2:-\033[2m}"
    local w=$(get_terminal_width)
    local wrap_width=$((w - 8))
    local prefix="\033[2m│\033[0m     "

    echo "- $text" | fold -s -w "$wrap_width" | while IFS= read -r wrapped_line; do
        echo -e "${prefix}${color}$wrapped_line\033[0m"
    done
}

# ============================================================
# Data Fetching (GraphQL, cross-repo, org-scoped)
# ============================================================

# Get authored open PRs from today + yesterday using GitHub GraphQL search
get_authored_prs() {
    local yesterday="$1"
    local org="$2"

    local search_query="author:@me created:>=${yesterday} org:${org} is:pr is:open"

    gh api graphql -f query="
    {
      search(query: \"${search_query}\", type: ISSUE, first: 50) {
        nodes {
          ... on PullRequest {
            number
            title
            url
            isDraft
            reviewDecision
            createdAt
            repository { nameWithOwner }
            labels(first: 5) { nodes { name } }
          }
        }
      }
    }" --jq '.data.search.nodes | [.[] | select(.number != null) | {
        number,
        title,
        url,
        isDraft,
        reviewDecision,
        createdAt,
        repo: .repository.nameWithOwner,
        labels: [.labels.nodes[]]
    }]' 2>/dev/null || echo "[]"
}

# Get PRs merged today + yesterday
get_merged_prs() {
    local yesterday="$1"
    local org="$2"

    local search_query="author:@me is:pr is:merged merged:>=${yesterday} org:${org}"

    gh api graphql -f query="
    {
      search(query: \"${search_query}\", type: ISSUE, first: 50) {
        nodes {
          ... on PullRequest {
            number
            title
            url
            body
            mergedAt
            additions
            deletions
            changedFiles
            repository { nameWithOwner }
            labels(first: 5) { nodes { name } }
          }
        }
      }
    }" --jq '.data.search.nodes | [.[] | select(.number != null) | {
        number,
        title,
        url,
        body: (.body | split("\n")[0:5] | join(" ") | .[0:300]),
        mergedAt,
        additions,
        deletions,
        changedFiles,
        repo: .repository.nameWithOwner,
        labels: [.labels.nodes[]]
    }]' 2>/dev/null || echo "[]"
}

# Get PRs where review is requested from you
get_review_requested_prs() {
    local org="$1"

    local search_query="review-requested:@me is:pr is:open org:${org}"

    gh api graphql -f query="
    {
      search(query: \"${search_query}\", type: ISSUE, first: 50) {
        nodes {
          ... on PullRequest {
            number
            title
            url
            isDraft
            reviewDecision
            createdAt
            author { login }
            repository { nameWithOwner }
          }
        }
      }
    }" --jq '.data.search.nodes | [.[] | select(.number != null and .isDraft == false and (.reviewDecision == "REVIEW_REQUIRED" or .reviewDecision == null)) | {
        number,
        title,
        url,
        isDraft,
        reviewDecision,
        createdAt,
        author: {login: .author.login},
        repo: .repository.nameWithOwner
    }]' 2>/dev/null || echo "[]"
}

# Get Linear issues assigned to current user (only recently active ones)
get_linear_issues() {
    if ! command -v linear &> /dev/null; then
        echo "[]"
        return 0
    fi

    local cutoff_date
    if [[ "$OSTYPE" == "darwin"* ]]; then
        cutoff_date=$(date -v-${LINEAR_RECENCY_DAYS}d +%Y-%m-%d 2>/dev/null || echo "")
    else
        cutoff_date=$(date -d "${LINEAR_RECENCY_DAYS} days ago" +%Y-%m-%d 2>/dev/null || echo "")
    fi

    local teams
    teams=$(linear team list 2>/dev/null | sed 's/\x1b\[[0-9;]*m//g' | awk 'NR>1 && $1 != "" && $1 != "KEY" && $1 != "Usage:" && $1 != "Version:" && $1 != "Description:" && $1 != "Options:" && $1 != "Commands:" && $1 != "List" {print $1}' | grep -E '^[A-Z]{2,4}$') || {
        print_info "Warning: Could not fetch Linear teams. Skipping Linear issues."
        echo "[]"
        return 0
    }

    if [ -z "$teams" ]; then
        echo "[]"
        return 0
    fi

    local all_issues=()

    while IFS= read -r team; do
        if [ -z "$team" ] || [[ ! "$team" =~ ^[A-Z]{2,4}$ ]]; then
            continue
        fi

        local team_issues
        team_issues=$(LINEAR_ISSUE_SORT=priority linear issue list \
            --team "$team" \
            --state unstarted \
            --state started \
            --no-pager 2>/dev/null | sed 's/\x1b\[[0-9;]*m//g') || continue

        if [ -z "$team_issues" ] || [[ "$team_issues" =~ "Could not determine team key" ]] || [[ "$team_issues" =~ "^[[:space:]]*$" ]]; then
            continue
        fi

        while IFS= read -r line; do
            if [ -z "$line" ] || \
               [[ "$line" =~ ^[[:space:]]*$ ]] || \
               [[ "$line" =~ ^[[:space:]]*ID[[:space:]]+TITLE ]] || \
               [[ "$line" =~ ^[[:space:]]*[▄▆█◌]+[[:space:]]*$ ]]; then
                continue
            fi

            local issue_id
            issue_id=$(echo "$line" | grep -oE '[A-Z]{2,4}-[0-9]+' | head -1)

            if [ -z "$issue_id" ]; then
                continue
            fi

            local updated_str
            updated_str=$(echo "$line" | grep -oE '[0-9]+ (hours?|days?) ago' | head -1)

            if [ -n "$cutoff_date" ] && [ -n "$updated_str" ]; then
                local days_ago=0
                if [[ "$updated_str" =~ ([0-9]+)[[:space:]]+days?[[:space:]]+ago ]]; then
                    days_ago="${BASH_REMATCH[1]}"
                elif [[ "$updated_str" =~ ([0-9]+)[[:space:]]+hours?[[:space:]]+ago ]]; then
                    days_ago=0
                fi

                if [ "$days_ago" -gt "$LINEAR_RECENCY_DAYS" ]; then
                    continue
                fi
            fi

            local title
            title=$(echo "$line" | sed "s/.*$issue_id[[:space:]]*//" | sed 's/[[:space:]]*-[[:space:]]*In Progress.*//' | sed 's/[[:space:]]*-[[:space:]]*In Review.*//' | sed 's/[[:space:]]*-[[:space:]]*[0-9].*//' | sed 's/[[:space:]]*Scheduling Task.*//' | sed 's/[[:space:]]*Epic.*//' | sed 's/[[:space:]]*Us.*//' | sed 's/[[:space:]]*$//')

            title=$(echo "$title" | sed 's/[[:space:]]*-[[:space:]]*$//' | sed 's/[[:space:]]*$//' | xargs)

            if [ -n "$title" ] && [ "$title" != "" ] && [ ${#title} -gt 3 ]; then
                local url
                url=$(linear issue url "$issue_id" 2>/dev/null | tr -d '\n\r' || echo "")

                local issue_json
                issue_json=$(jq -n \
                    --arg id "$issue_id" \
                    --arg title "$title" \
                    --arg url "$url" \
                    --arg team "$team" \
                    --arg updated "$updated_str" \
                    '{id: $id, title: $title, url: $url, team: $team, updated: $updated}' 2>/dev/null) || continue

                if [ -n "$issue_json" ]; then
                    all_issues+=("$issue_json")
                fi
            fi
        done <<< "$team_issues"
    done <<< "$teams"

    if [ ${#all_issues[@]} -eq 0 ]; then
        echo "[]"
    else
        printf '%s\n' "${all_issues[@]}" | jq -s '.' 2>/dev/null || echo "[]"
    fi
}

# ============================================================
# Rendering
# ============================================================

render_box_style() {
    local prs_json="$1"
    local prs_needing_review_json="$2"
    local linear_issues_json="$3"
    local date="$4"
    local merged_json="${5:-[]}"
    local width=$(get_terminal_width)
    local today=$(get_today_date)
    local yesterday=$(get_yesterday_date)
    local formatted_date=$(date "+%a %b %-d" 2>/dev/null || date "+%a %b %d")

    # Header
    echo ""
    draw_box "$width" "📊 Standup · $formatted_date"
    echo ""

    # ── Action Items ──
    local merged_count=$(echo "$merged_json" | jq 'length' 2>/dev/null || echo "0")
    local approved_count=$(echo "$prs_json" | jq '[.[] | select(.isDraft == false and .reviewDecision == "APPROVED")] | length' 2>/dev/null || echo "0")
    local changes_count=$(echo "$prs_json" | jq '[.[] | select(.reviewDecision == "CHANGES_REQUESTED")] | length' 2>/dev/null || echo "0")
    local review_pr_count=$(echo "$prs_needing_review_json" | jq 'length' 2>/dev/null || echo "0")

    echo -e "  ${BOLD}⚡ Action Items${NC}"
    [ "${merged_count:-0}" -gt 0 ] && echo -e "  ${GREEN}🚀 $merged_count shipped${NC}"
    [ "${approved_count:-0}" -gt 0 ] && echo -e "  ${GREEN}🟢 $approved_count approved → ready to merge${NC}"
    [ "${changes_count:-0}" -gt 0 ] && echo -e "  ${RED}🔴 $changes_count with changes requested${NC}"
    [ "${review_pr_count:-0}" -gt 0 ] && echo -e "  ${YELLOW}👀 $review_pr_count PR(s) need your review${NC}"
    if [ "${merged_count:-0}" -eq 0 ] && [ "${approved_count:-0}" -eq 0 ] && [ "${changes_count:-0}" -eq 0 ] && [ "${review_pr_count:-0}" -eq 0 ]; then
        echo -e "  ${DIM}No action items${NC}"
    fi
    echo ""

    # ── Collect all repos from both merged + open ──
    local all_repos
    all_repos=$(echo "$merged_json $prs_json" | jq -rs '[.[][].repo // empty] | unique | .[]' 2>/dev/null)

    if [ -n "$all_repos" ]; then
        while IFS= read -r repo; do
            [ -z "$repo" ] && continue
            local repo_name=$(repo_short "$repo")

            # Count merged + open for this repo
            local repo_merged_count=$(echo "$merged_json" | jq --arg r "$repo" '[.[] | select(.repo == $r)] | length' 2>/dev/null || echo "0")
            local repo_open_count=$(echo "$prs_json" | jq --arg r "$repo" '[.[] | select(.repo == $r and .isDraft == false)] | length' 2>/dev/null || echo "0")
            local repo_draft_count=$(echo "$prs_json" | jq --arg r "$repo" '[.[] | select(.repo == $r and .isDraft == true)] | length' 2>/dev/null || echo "0")

            # Build subtitle
            local subtitle_parts=()
            [ "${repo_merged_count:-0}" -gt 0 ] && subtitle_parts+=("$repo_merged_count shipped")
            [ "${repo_open_count:-0}" -gt 0 ] && subtitle_parts+=("$repo_open_count open")
            [ "${repo_draft_count:-0}" -gt 0 ] && subtitle_parts+=("$repo_draft_count draft")
            local subtitle=$(IFS=', '; echo "${subtitle_parts[*]}")

            echo -e "${CYAN}${BOLD}${BOX_TL}─ $repo_name${NC} ${DIM}($subtitle)${NC}"
            echo -e "${CYAN}${BOX_V}${NC}"

            # ── Shipped (merged PRs for this repo) ──
            if [ "${repo_merged_count:-0}" -gt 0 ]; then
                echo -e "${CYAN}${BOX_V}${NC}  ${GREEN}${BOLD}🚀 Shipped${NC}"

                echo "$merged_json" | jq -c --arg r "$repo" '[.[] | select(.repo == $r)] | sort_by(.mergedAt) | reverse | .[]' 2>/dev/null | while IFS= read -r pr; do
                    local title=$(echo "$pr" | jq -r '.title')
                    local number=$(echo "$pr" | jq -r '.number')
                    local url=$(echo "$pr" | jq -r '.url')
                    local merged_at=$(echo "$pr" | jq -r '.mergedAt')
                    local merge_date=$(echo "$merged_at" | cut -d'T' -f1)
                    local labels=$(echo "$pr" | jq -r '[.labels[].name // empty] | join(", ")' 2>/dev/null)
                    local title_short=$(truncate_text "$title" $((width - 25)))

                    local day_tag=""
                    if [ "$merge_date" = "$today" ]; then
                        day_tag="  ${GREEN}today${NC}"
                    elif [ "$merge_date" = "$yesterday" ]; then
                        day_tag="  ${DIM}yesterday${NC}"
                    fi

                    local label_tag=""
                    [ -n "$labels" ] && [ "$labels" != "" ] && label_tag="  ${DIM}$labels${NC}"

                    printf "${CYAN}${BOX_V}${NC}   ${GREEN}✓${NC} ${BOLD}$title_short${NC}  ${DIM}"
                    printf '\033]8;;%s\033\\%s\033]8;;\033\\' "$url" "#$number"
                    printf "${NC}$day_tag$label_tag\n"
                done

                echo -e "${CYAN}${BOX_V}${NC}"
            fi

            # ── Open (non-draft PRs for this repo) ──
            if [ "${repo_open_count:-0}" -gt 0 ]; then
                echo -e "${CYAN}${BOX_V}${NC}  ${BLUE}${BOLD}Open${NC}"

                echo "$prs_json" | jq -c --arg r "$repo" '[.[] | select(.repo == $r and .isDraft == false)] | sort_by(.createdAt) | reverse | .[]' 2>/dev/null | while IFS= read -r pr; do
                    local title=$(echo "$pr" | jq -r '.title')
                    local number=$(echo "$pr" | jq -r '.number')
                    local url=$(echo "$pr" | jq -r '.url')
                    local review_decision=$(echo "$pr" | jq -r '.reviewDecision // "null"')
                    local labels=$(echo "$pr" | jq -r '[.labels[].name // empty] | join(", ")' 2>/dev/null)
                    local title_short=$(truncate_text "$title" $((width - 25)))

                    local icon="${BLUE}○${NC}"
                    local status_tag=""
                    if [ "$review_decision" = "APPROVED" ]; then
                        icon="${GREEN}🟢${NC}"
                        status_tag="  ${GREEN}APPROVED${NC}"
                    elif [ "$review_decision" = "CHANGES_REQUESTED" ]; then
                        icon="${RED}🔴${NC}"
                        status_tag="  ${RED}CHANGES${NC}"
                    fi

                    local label_tag=""
                    [ -n "$labels" ] && [ "$labels" != "" ] && label_tag="  ${DIM}$labels${NC}"

                    printf "${CYAN}${BOX_V}${NC}   $icon ${BOLD}$title_short${NC}  ${DIM}"
                    printf '\033]8;;%s\033\\%s\033]8;;\033\\' "$url" "#$number"
                    printf "${NC}$status_tag$label_tag\n"
                done

                echo -e "${CYAN}${BOX_V}${NC}"
            fi

            # ── Drafts (collapsed) ──
            if [ "${repo_draft_count:-0}" -gt 0 ]; then
                local draft_groups
                draft_groups=$(echo "$prs_json" | jq -c --arg r "$repo" \
                    '[.[] | select(.repo == $r and .isDraft == true)] |
                     group_by(.title) | .[] |
                     {title: .[0].title, numbers: [.[].number], urls: [.[].url], count: length}' 2>/dev/null)

                if [ -n "$draft_groups" ]; then
                    echo "$draft_groups" | while IFS= read -r group; do
                        local draft_title=$(echo "$group" | jq -r '.title')
                        local draft_count=$(echo "$group" | jq -r '.count')
                        local draft_numbers=$(echo "$group" | jq -r '.numbers | map("#\(.)") | join(", ")')

                        if [ "$draft_count" -gt 1 ]; then
                            echo -e "${CYAN}${BOX_V}${NC}   ${YELLOW}📝${NC} ${DIM}$draft_count drafts ($draft_numbers)${NC}"
                        else
                            local draft_url=$(echo "$group" | jq -r '.urls[0]')
                            local draft_num=$(echo "$group" | jq -r '.numbers[0]')
                            local draft_title_short=$(truncate_text "$draft_title" $((width - 20)))
                            printf "${CYAN}${BOX_V}${NC}   ${YELLOW}📝${NC} ${DIM}$draft_title_short${NC}  ${DIM}"
                            printf '\033]8;;%s\033\\%s\033]8;;\033\\' "$draft_url" "#$draft_num"
                            printf "${NC}\n"
                        fi
                    done
                    echo -e "${CYAN}${BOX_V}${NC}"
                fi
            fi

            echo -e "${CYAN}${BOX_BL}${BOX_H}${NC}"
            echo ""
        done <<< "$all_repos"
    fi

    # ── PRs Needing Review ──
    if [ "${review_pr_count:-0}" -gt 0 ]; then
        echo -e "${YELLOW}${BOLD}${BOX_TL}─ 👀 Needs Your Review${NC}"
        echo -e "${YELLOW}${BOX_V}${NC}"

        echo "$prs_needing_review_json" | jq -c '.[]' | while IFS= read -r pr; do
            local title=$(echo "$pr" | jq -r '.title')
            local number=$(echo "$pr" | jq -r '.number')
            local author=$(echo "$pr" | jq -r '.author.login')
            local url=$(echo "$pr" | jq -r '.url')
            local repo=$(echo "$pr" | jq -r '.repo // ""')
            local repo_name=$(repo_short "$repo")
            local title_short=$(truncate_text "$title" $((width - 30)))

            printf "${YELLOW}${BOX_V}${NC}   ${YELLOW}⚠${NC} ${DIM}$repo_name${NC} ${BOLD}$title_short${NC}  ${DIM}"
            printf '\033]8;;%s\033\\%s\033]8;;\033\\' "$url" "#$number"
            printf "${NC} by @$author\n"
        done

        echo -e "${YELLOW}${BOX_V}${NC}"
        echo -e "${YELLOW}${BOX_BL}${BOX_H}${NC}"
        echo ""
    fi

    # ── Linear Issues ──
    local linear_count=$(echo "$linear_issues_json" | jq -r 'length' 2>/dev/null || echo "0")
    if [ "${linear_count:-0}" -gt 0 ]; then
        echo -e "${MAGENTA}${BOLD}${BOX_TL}─ 📋 Linear Issues ($linear_count)${NC}"
        echo -e "${MAGENTA}${BOX_V}${NC}"

        echo "$linear_issues_json" | jq -c '.[]' | while IFS= read -r issue; do
            local title=$(echo "$issue" | jq -r '.title')
            local id=$(echo "$issue" | jq -r '.id')
            local url=$(echo "$issue" | jq -r '.url')
            local team=$(echo "$issue" | jq -r '.team')
            local title_short=$(truncate_text "$title" $((width - 20)))

            if [ -n "$url" ] && [ "$url" != "null" ] && [ "$url" != "" ]; then
                printf "${MAGENTA}${BOX_V}${NC}   ${BOLD}[$team]${NC} $title_short  ${DIM}"
                printf '\033]8;;%s\033\\%s\033]8;;\033\\' "$url" "$id"
                printf "${NC}\n"
            else
                echo -e "${MAGENTA}${BOX_V}${NC}   ${BOLD}[$team]${NC} $title_short ${DIM}$id${NC}"
            fi
        done

        echo -e "${MAGENTA}${BOX_V}${NC}"
        echo -e "${MAGENTA}${BOX_BL}${BOX_H}${NC}"
    fi
}

