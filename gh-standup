generate_standup_report() {
    local prs_json="$1"
    local prs_needing_review_json="$2"
    local linear_issues_json="$3"
    local date="$4"
    local merged_json="${5:-[]}"

    [ -z "$prs_json" ] || [ "$prs_json" = "" ] && prs_json="[]"
    [ -z "$prs_needing_review_json" ] || [ "$prs_needing_review_json" = "" ] && prs_needing_review_json="[]"
    [ -z "$linear_issues_json" ] || [ "$linear_issues_json" = "" ] && linear_issues_json="[]"
    [ -z "$merged_json" ] || [ "$merged_json" = "" ] && merged_json="[]"

    case "$STANDUP_STYLE" in
        box)
            render_box_style "$prs_json" "$prs_needing_review_json" "$linear_issues_json" "$date" "$merged_json"
            ;;
        colorful)
            render_colorful_style "$prs_json" "$prs_needing_review_json" "$linear_issues_json" "$date"
            ;;
        table)
            render_table_style "$prs_json" "$prs_needing_review_json" "$linear_issues_json" "$date"
            ;;
        minimal)
            render_minimal_style "$prs_json" "$prs_needing_review_json" "$linear_issues_json" "$date"
            ;;
        *)
            print_error "Unknown style: $STANDUP_STYLE"
            print_info "Available styles: box, colorful, table, minimal"
            render_box_style "$prs_json" "$prs_needing_review_json" "$linear_issues_json" "$date" "$merged_json"
            ;;
    esac

    # Generate and display AI summary if enabled
    if [ "$STANDUP_SUMMARY" = "1" ]; then
        printf "${DIM}Generating summary...${NC}"
        local summary_output
        summary_output=$(generate_summary "$prs_json" "$prs_needing_review_json" "$linear_issues_json" "$merged_json" 2>&1)
        printf "\r\033[K"
        if [ -n "$summary_output" ] && echo "$summary_output" | jq empty 2>/dev/null; then
            echo -e "${DIM}${BOX_TL}─ 📝 Standup${NC}"
            echo -e "${DIM}${BOX_V}${NC}"

            echo -e "${DIM}${BOX_V}${NC}  ${GREEN}${BOLD}Yesterday${NC}"
            echo "$summary_output" | jq -r '.yesterday[]' 2>/dev/null | while IFS= read -r bullet; do
                wrap_bullet "$bullet" "$DIM"
            done
            echo -e "${DIM}${BOX_V}${NC}"

            echo -e "${DIM}${BOX_V}${NC}  ${BLUE}${BOLD}Today${NC}"
            echo "$summary_output" | jq -r '.today[]' 2>/dev/null | while IFS= read -r bullet; do
                wrap_bullet "$bullet" "$DIM"
            done
            echo -e "${DIM}${BOX_V}${NC}"

            echo -e "${DIM}${BOX_V}${NC}  ${YELLOW}${BOLD}Blockers${NC}"
            echo "$summary_output" | jq -r '.blockers[]' 2>/dev/null | while IFS= read -r bullet; do
                if [[ "$bullet" == "None" ]] || [[ "$bullet" == "none" ]]; then
                    echo -e "${DIM}${BOX_V}${NC}     ${DIM}- None${NC}"
                else
                    wrap_bullet "$bullet" "$YELLOW"
                fi
            done
            echo -e "${DIM}${BOX_V}${NC}"
            echo -e "${DIM}${BOX_BL}${BOX_H}${NC}"
            echo ""
        fi
    fi
}

